{
  "_version": "1.60.0",
  "sap.app": {
    "id": "crm",
    "type": "application",
    "title": "Trade Immobiliare CRM",
    "applicationVersion": {
      "version": "1.0.0"
    }
  },
  "sap.ui5": {
    "rootView": {
      "viewName": "crm.view.App",
      "type": "XML",
      "id": "app"
    },
    "dependencies": {
      "minUI5Version": "1.120.0",
      "libs": {
        "sap.f": {},
        "sap.m": {},
        "sap.uxap": {},
        "sap.tnt": {},
        "sap.ui.core": {},
        "sap.ui.layout": {},
        "sap.ui.unified": {}
      }
    },
    "models": {
      "i18n": {
        "type": "sap.ui.model.resource.ResourceModel",
        "settings": {
          "bundleName": "crm.i18n.i18n",
          "supportedLocales": [
            "",
            "it",
            "it_IT",
            "en",
            "en_US"
          ],
          "fallbackLocale": ""
        }
      },
      "categoriesContact": {
        "type": "sap.ui.model.json.JSONModel",
        "uri": "model/modelCategoriesContact.json"
      },
      "statesContact": {
        "type": "sap.ui.model.json.JSONModel",
        "uri": "model/modelStatesContact.json"
      },
      "valueMutuo": {
        "type": "sap.ui.model.json.JSONModel",
        "uri": "model/modelValueMutuo.json"
      },
      "statesProperty": {
        "type": "sap.ui.model.json.JSONModel",
        "uri": "model/modelStatesProperty.json"
      },
      "typeProperties": {
        "type": "sap.ui.model.json.JSONModel",
        "uri": "model/modelTypeProperties.json"
      },
      "activityTypes": {
        "type": "sap.ui.model.json.JSONModel",
        "uri": "model/modelTypesNote.json"
      },
      "activityStates": {
        "type": "sap.ui.model.json.JSONModel",
        "uri": "model/modelActivityStates.json"
      },
      "favoriteFloor": {
        "type": "sap.ui.model.json.JSONModel",
        "uri": "model/modelFavoriteFloor.json"
      },
      "buyerPreferences": {
        "type": "sap.ui.model.json.JSONModel",
        "uri": "model/modelBuyerPreferences.json"
      },
      "characteristicsProperty": {
        "type": "sap.ui.model.json.JSONModel",
        "uri": "model/modelCharacteristicsProperty.json"
      }
    },
    "routing": {
      "config": {
        "routerClass": "sap.m.routing.Router",
        "viewType": "XML",
        "viewPath": "crm.view",
        "controlId": "appNavContainer",
        "controlAggregation": "pages",
        "async": true,
        "bypassed": {
          "target": "login"
        }
      },
      "routes": [
        {
          "pattern": "",
          "name": "login",
          "target": "login"
        },
        {
          "pattern": "home",
          "name": "home",
          "target": "home"
        },
        {
          "pattern": "contacts",
          "name": "contacts",
          "target": "contacts"
        },
        {
          "pattern": "contacts/{contactId}",
          "name": "contactDetail",
          "target": "contactDetail"
        },
        {
          "pattern": "properties",
          "name": "properties",
          "target": "properties"
        },
        {
          "pattern": "properties/{propertyId}",
          "name": "propertyDetail",
          "target": "propertyDetail"
        },
        {
          "pattern": "profile",
          "name": "userProfile",
          "target": "userProfile"
        },
        {
          "pattern": "calendartoday",
          "name": "calendarToday",
          "target": "calendarToday"
        }
      ],
      "targets": {
        "login": {
          "viewName": "Login",
          "viewId": "login"
        },
        "home": {
          "viewName": "Home",
          "viewId": "home"
        },
        "contacts": {
          "viewName": "contactTile.Contacts",
          "viewId": "contacts"
        },
        "contactDetail": {
          "viewName": "contactTile.ContactDetail",
          "viewId": "contactDetail"
        },
        "properties": {
          "viewName": "propertyTile.Property",
          "viewId": "properties"
        },
        "propertyDetail": {
          "viewName": "propertyTile.DetailProperty",
          "viewId": "propertyDetail"
        },
        "userProfile": {
          "viewName": "UserProfile",
          "viewId": "userProfile"
        },
        "calendarToday": {
          "viewName": "calendartoday.CalendarToday",
          "viewId": "calendarToday"
        }
      }
    }
  }
}
