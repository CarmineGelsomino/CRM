<mvc:View
    controllerName="crm.controller.Home"
    xmlns="sap.m"
    xmlns:mvc="sap.ui.core.mvc"
    xmlns:layout="sap.ui.layout"
    xmlns:core="sap.ui.core">
    <Page class="sapUiResponsiveContentPadding" enableScrolling="true">
        <customHeader>
            <core:Fragment fragmentName="crm.view.fragments.ShellBar" type="XML" />
        </customHeader>
        <content>
            <VBox class="sapUiSmallMarginBottom" width="100%">
                <Title text="{i18n>homeVersionTitle}" level="H2" />
                <Text text="{i18n>shellBarSubtitle}" class="sapUiTinyMarginTop" />
            </VBox>
            <HBox justifyContent="Center" gap="30px" renderType="Bare" wrap="Wrap">
                <GenericTile id="calendarTodayTile" header="{i18n>homeTileTodayBoardHeader}" subheader="{i18n>homeTileTodayBoardSubheader}" press="onTilePress" frameType="TwoByOne">
                    <TileContent footer="{i18n>homeTileOpenModule}">
                        <NumericContent value="14" scale="{i18n>homeTileDefaultScale}" valueColor="Neutral" />
                    </TileContent>
                </GenericTile>

                <GenericTile id="contactsTile" header="{i18n>homeTileContactsHeader}" subheader="{i18n>homeTileContactsSubheader}" press="onTilePress" frameType="TwoByOne">
                    <TileContent footer="{i18n>homeTileOpenModule}">
                        <NumericContent value="128" scale="{i18n>homeTileContactsScale}" valueColor="Good" />
                    </TileContent>
                </GenericTile>

                <GenericTile id="propertiesTile" header="{i18n>homeTilePropertiesHeader}" subheader="{i18n>homeTilePropertiesSubheader}" press="onTilePress" frameType="TwoByOne">
                    <TileContent footer="{i18n>homeTileOpenModule}">
                        <NumericContent value="36" scale="{i18n>homeTilePropertiesScale}" valueColor="Critical" />
                    </TileContent>
                </GenericTile>

                <GenericTile header="{i18n>homeTileCommunicationsHeader}" subheader="{i18n>homeTileCommunicationsSubheader}" press="onTilePress" frameType="TwoByOne">
                    <TileContent footer="{i18n>homeTileOpenModule}">
                        <NumericContent value="14" scale="{i18n>homeTileDefaultScale}" valueColor="Neutral" />
                    </TileContent>
                </GenericTile>

                <GenericTile header="{i18n>homeTileCalendarHeader}" subheader="{i18n>homeTileCalendarSubheader}" press="onTilePress" frameType="TwoByOne">
                    <TileContent footer="{i18n>homeTileOpenModule}">
                        <NumericContent value="14" scale="{i18n>homeTileDefaultScale}" valueColor="Neutral" />
                    </TileContent>
                </GenericTile>

                <GenericTile header="{i18n>homeTileActivitiesHeader}" subheader="{i18n>homeTileActivitiesSubheader}" press="onTilePress" frameType="TwoByOne">
                    <TileContent footer="{i18n>homeTileOpenModule}">
                        <NumericContent value="14" scale="{i18n>homeTileDefaultScale}" valueColor="Neutral" />
                    </TileContent>
                </GenericTile>

                <GenericTile id="notesTile" header="{i18n>homeTileNotesHeader}" subheader="{i18n>homeTileNotesSubheader}" press="onTilePress" frameType="TwoByOne">
                    <TileContent footer="{i18n>homeTileOpenModule}">
                        <NumericContent value="14" scale="{i18n>homeTileDefaultScale}" valueColor="Neutral" />
                    </TileContent>
                </GenericTile>

                <GenericTile header="{i18n>homeTileStatisticsHeader}" subheader="{i18n>homeTileStatisticsSubheader}" press="onTilePress" frameType="TwoByOne">
                    <TileContent footer="{i18n>homeTileOpenModule}">
                        <NumericContent value="14" scale="{i18n>homeTileDefaultScale}" valueColor="Neutral" />
                    </TileContent>
                </GenericTile>
            </HBox>
        </content>
    </Page>
</mvc:View>
