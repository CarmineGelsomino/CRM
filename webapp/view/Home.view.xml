<mvc:View
    controllerName="crm.controller.Home"
    xmlns="sap.m"
    xmlns:mvc="sap.ui.core.mvc"
    xmlns:layout="sap.ui.layout"
    xmlns:core="sap.ui.core">
    <Page class="sapUiResponsiveContentPadding" enableScrolling="true">
        <customHeader>
            <core:Fragment fragmentName="crm.view.fragments.ShellBar" type="XML" />
        </customHeader>
        <content>
            <VBox class="sapUiSmallMarginBottom" width="100%">
                <Title text="Versione 2026 v1.0" level="H2" />
                <Text text="{i18n>shellBarSubtitle}" class="sapUiTinyMarginTop" />
            </VBox>
            <HBox justifyContent="Center" gap="30px" renderType="Bare" wrap="Wrap">
                <GenericTile header="TodayBoard" subheader="Tutte le attivita da fare oggi" press="onTilePress" frameType="TwoByOne">
                    <TileContent footer="Apri modulo">
                        <NumericContent value="14" scale="in gestione" valueColor="Neutral" />
                    </TileContent>
                </GenericTile>

                <GenericTile id="contactsTile" header="Contatti" subheader="Contatti e relative anagrafiche" press="onTilePress" frameType="TwoByOne">
                    <TileContent footer="Apri modulo">
                        <NumericContent value="128" scale="attivi" valueColor="Good" />
                    </TileContent>
                </GenericTile>

                <GenericTile id="propertiesTile" header="Proprieta" subheader="Proprieta e relativi dettagli" press="onTilePress" frameType="TwoByOne">
                    <TileContent footer="Apri modulo">
                        <NumericContent value="36" scale="aperte" valueColor="Critical" />
                    </TileContent>
                </GenericTile>

                <GenericTile header="Comunicazioni" subheader="Comunicazioni" press="onTilePress" frameType="TwoByOne">
                    <TileContent footer="Apri modulo">
                        <NumericContent value="14" scale="in gestione" valueColor="Neutral" />
                    </TileContent>
                </GenericTile>

                <GenericTile header="Calendario" subheader="Calendario delle varie attivita da fare" press="onTilePress" frameType="TwoByOne">
                    <TileContent footer="Apri modulo">
                        <NumericContent value="14" scale="in gestione" valueColor="Neutral" />
                    </TileContent>
                </GenericTile>

                <GenericTile header="Attivita" subheader="Storico delle attivita generali" press="onTilePress" frameType="TwoByOne">
                    <TileContent footer="Apri modulo">
                        <NumericContent value="14" scale="in gestione" valueColor="Neutral" />
                    </TileContent>
                </GenericTile>

                <GenericTile header="Note" subheader="Storico delle note generali" press="onTilePress" frameType="TwoByOne">
                    <TileContent footer="Apri modulo">
                        <NumericContent value="14" scale="in gestione" valueColor="Neutral" />
                    </TileContent>
                </GenericTile>

                <GenericTile header="Statistiche" subheader="Varie statistiche" press="onTilePress" frameType="TwoByOne">
                    <TileContent footer="Apri modulo">
                        <NumericContent value="14" scale="in gestione" valueColor="Neutral" />
                    </TileContent>
                </GenericTile>
            </HBox>
        </content>
    </Page>
</mvc:View>
