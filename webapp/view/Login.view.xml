<mvc:View
    controllerName="crm.controller.Login"
    xmlns="sap.m"
    xmlns:mvc="sap.ui.core.mvc"
    xmlns:layout="sap.ui.layout">
    <Page showHeader="false" class="sapUiResponsiveContentPadding">
        <content>
            <layout:VerticalLayout width="100%" class="sapUiLargeMarginTop sapUiResponsiveMargin">
                <Panel width="auto" class="sapUiResponsiveMargin" expandable="false">
                    <headerToolbar>
                        <Toolbar>
                            <Title text="{i18n>loginTitle}" level="H2" />
                        </Toolbar>
                    </headerToolbar>
                    <content>
                        <VBox class="sapUiSmallMargin" renderType="Bare">
                            <Text text="{i18n>loginSubtitle}" wrapping="true" class="sapUiSmallMarginBottom" />

                            <Label text="{i18n>loginUsernameLabel}" labelFor="usernameInput" />
                            <Input
                                id="usernameInput"
                                value="{session>/username}"
                                valueState="{session>/usernameState}"
                                valueStateText="{i18n>loginUsernameRequired}"
                                placeholder="{i18n>loginUsernamePlaceholder}"
                                width="100%"
                                submit="onLogin" />

                            <Label text="{i18n>loginPasswordLabel}" labelFor="passwordInput" class="sapUiSmallMarginTop" />
                            <Input
                                id="passwordInput"
                                type="Password"
                                value="{session>/password}"
                                valueState="{session>/passwordState}"
                                valueStateText="{i18n>loginPasswordRequired}"
                                placeholder="{i18n>loginPasswordPlaceholder}"
                                width="100%"
                                submit="onLogin" />

                            <MessageStrip
                                text="{session>/loginMessage}"
                                type="Error"
                                visible="{= !!${session>/loginMessage} }"
                                class="sapUiSmallMarginTop" />

                            <Button
                                text="{i18n>loginButton}"
                                type="Emphasized"
                                class="sapUiMediumMarginTop"
                                width="100%"
                                press="onLogin" />
                        </VBox>
                    </content>
                </Panel>
            </layout:VerticalLayout>
        </content>
    </Page>
</mvc:View>
