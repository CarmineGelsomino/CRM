<mvc:View
    controllerName="crm.controller.Login"
    xmlns="sap.m"
    xmlns:mvc="sap.ui.core.mvc"
    xmlns:layout="sap.ui.layout">
    <Page showHeader="false" class="sapUiResponsiveContentPadding">
        <content>
            <layout:VerticalLayout width="100%" class="sapUiLargeMarginTop sapUiResponsiveMargin">
                <Panel width="auto" class="sapUiResponsiveMargin" expandable="false">
                    <headerToolbar>
                        <Toolbar>
                            <Title text="CRM Login" level="H2" />
                        </Toolbar>
                    </headerToolbar>
                    <content>
                        <VBox class="sapUiSmallMargin" renderType="Bare">
                            <Label text="Username" labelFor="usernameInput" />
                            <Input id="usernameInput" value="{session>/username}" width="100%" />

                            <Label text="Password" labelFor="passwordInput" class="sapUiSmallMarginTop" />
                            <Input id="passwordInput" type="Password" value="{session>/password}" width="100%" />

                            <Button
                                text="Accedi"
                                type="Emphasized"
                                class="sapUiMediumMarginTop"
                                width="100%"
                                press="onLogin" />
                        </VBox>
                    </content>
                </Panel>
            </layout:VerticalLayout>
        </content>
    </Page>
</mvc:View>
