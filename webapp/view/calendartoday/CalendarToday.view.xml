<mvc:View
    controllerName="crm.controller.calendartoday.CalendarToday"
    xmlns="sap.m"
    xmlns:mvc="sap.ui.core.mvc"
    xmlns:core="sap.ui.core"
    xmlns:unified="sap.ui.unified">
    <Page class="sapUiResponsiveContentPadding" enableScrolling="true" title="{i18n>calendarTodayPageTitle}">
        <customHeader>
            <core:Fragment fragmentName="crm.view.fragments.ShellBar" type="XML" />
        </customHeader>
        <content>
            <Title class="sapUiSmallMargin" text="{i18n>calendarTodayPageTitle}" titleStyle="H2" />
            <VBox>
                <OverflowToolbar style="Clear">
                    <SearchField
                        width="22rem"
                        placeholder="{i18n>calendarTodayFilterPlaceholder}"
                        liveChange="onFilterActivities"
                        search="onFilterActivities"
                        value="{calendarToday>/search}" />
                    <ToolbarSeparator />
                    <Select width="12rem" selectedKey="{calendarToday>/status}" change="onFilterActivities" items="{calendarToday>/statusOptions}">
                        <core:Item key="{calendarToday>key}" text="{calendarToday>value}" />
                    </Select>
                    <Select width="12rem" selectedKey="{calendarToday>/type}" change="onFilterActivities" items="{calendarToday>/typeOptions}">
                        <core:Item key="{calendarToday>key}" text="{calendarToday>value}" />
                    </Select>
                    <ToolbarSpacer />
                    <ObjectStatus text="{= ${calendarToday>/summary/total} + ' ' + ${i18n>calendarTodaySummaryActivities} }" state="Information" />
                    <ObjectStatus text="{= ${calendarToday>/summary/contacts} + ' ' + ${i18n>calendarTodaySummaryContacts} }" state="Success" class="sapUiTinyMarginBegin" />
                </OverflowToolbar>
                <OverflowToolbar>
                    <ToolbarSpacer />
                    <Button tooltip="{i18n>contactDetailAddButton}" type="Emphasized" icon="sap-icon://add" press="onAddActivity" />
                    <Button icon="sap-icon://refresh" type="Transparent" tooltip="{i18n>calendarTodayRefresh}" press="onRefresh" />
                </OverflowToolbar>

                <SinglePlanningCalendar
                    id="todayPlanningCalendar"
                    class="sapUiContentPadding sapUiResponsiveMargin"
                    startDate="{calendarToday>/selectedDate}"
                    startHour="{calendarToday>/startHour}"
                    viewKey="Day"
                    fullDay="false"
                    stickyMode="All"
                    appointmentSelect="onAppointmentSelect"
                    noDataText="{i18n>calendarTodayNoData}"
                    appointments="{calendarToday>/appointments}"
                    busy="{calendarToday>/isBusy}">
                    <views>
                        <SinglePlanningCalendarDayView key="Day" title="Day" />
                    </views>
                    <appointments>
                        <unified:CalendarAppointment
                            startDate="{calendarToday>startDate}"
                            endDate="{calendarToday>endDate}"
                            title="{calendarToday>title}"
                            text="{calendarToday>text}"
                            icon="{calendarToday>icon}"
                            tooltip="{calendarToday>tooltip}"
                            color="{calendarToday>color}"
                            type="{calendarToday>type}" />
                    </appointments>
                </SinglePlanningCalendar>

                <FlexBox
                    wrap="Wrap"
                    alignItems="Center"
                    class="sapUiSmallMarginTop sapUiTinyMarginBottom"
                    items="{calendarTodayLegend>/items}">
                    <items>
                        <HBox alignItems="Center" class="sapUiSmallMarginEnd sapUiTinyMarginBottom">
                            <items>
                                <core:Icon src="sap-icon://circle-task-2" color="{calendarTodayLegend>colorHex}" class="sapUiTinyMarginEnd" />
                                <Text text="{calendarTodayLegend>label}" wrapping="false" />
                            </items>
                        </HBox>
                    </items>
                </FlexBox>
            </VBox>
        </content>
    </Page>
</mvc:View>
