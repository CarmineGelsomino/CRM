<mvc:View
    controllerName="crm.controller.contactTile.ContactDetail"
    xmlns="sap.m"
    xmlns:mvc="sap.ui.core.mvc"
    xmlns:core="sap.ui.core"
    xmlns:f="sap.ui.layout.form">
    
    <Page title="{i18n>contactDetailPageTitle}" class="sapUiResponsiveContentPadding" navButtonPress="onNavBack" showNavButton="true">
        <customHeader>
            <core:Fragment fragmentName="crm.view.fragments.ShellBar" type="XML"/>
        </customHeader>
        <content>
            <Title class="sapUiSmallMargin" text="{i18n>contactDetailPageTitle}" titleStyle="H2"/>
            <ObjectHeader
                title="{= ${contactDetail>/contact/first_name} + ' ' + ${contactDetail>/contact/last_name}}"
                intro="{contactDetail>/contact/category}"
                responsive="true">
                <attributes>
                    <ObjectAttribute text="{= ${i18n>contactDetailEmailPrefix} + ${contactDetail>/contact/email}}" />
                    <ObjectAttribute text="{= ${i18n>contactDetailPecPrefix} + ${contactDetail>/contact/pec_email}}" />
                </attributes>
                <statuses>
                    <ObjectStatus
                        text="{contactDetail>/contact/status}"
                        state="{= ${contactDetail>/contact/status} === 'Attivo' || ${contactDetail>/contact/status} === 'attivo' ? 'Success' : (${contactDetail>/contact/status} === 'Futuro' || ${contactDetail>/contact/status} === 'futuro' ? 'Warning' : 'None')}" />
                </statuses>
            </ObjectHeader>

            <f:SimpleForm editable="true" layout="ResponsiveGridLayout" title="{i18n>contactDetailSectionContactData}" class="sapUiSmallMarginTop">
                <f:content>
                    <Label text="{i18n>contactsDialogFieldFirstName}" />
                    <Input value="{contactDetail>/contact/first_name}" />
                    <Label text="{i18n>contactsDialogFieldLastName}" />
                    <Input value="{contactDetail>/contact/last_name}" />
                    <Label text="{i18n>contactsDialogFieldEmail}" />
                    <Input value="{contactDetail>/contact/email}" type="Email" />
                    <Label text="{i18n>contactsDialogFieldPec}" />
                    <Input value="{contactDetail>/contact/pec_email}" type="Email" />
                    <Label text="{i18n>contactsDialogFieldCategory}" />
                    <Select selectedKey="{contactDetail>/contact/category}" items="{categoriesContact>/}">
                        <core:Item key="{categoriesContact>key}" text="{categoriesContact>value}" />
                    </Select>
                    <Label text="{i18n>contactsDialogFieldStatus}" />
                    <Select selectedKey="{contactDetail>/contact/status}" items="{statesContact>/}">
                        <core:Item key="{statesContact>key}" text="{statesContact>value}" />
                    </Select>
                    <Label text="{i18n>contactDetailFieldInfo}" />
                    <TextArea rows="4" value="{contactDetail>/contact/generic_info}" />
                </f:content>
            </f:SimpleForm>

            <f:SimpleForm
                editable="true"
                layout="ResponsiveGridLayout"
                title="{i18n>contactDetailSectionBuyerProfile}"
                class="sapUiSmallMarginTop"
                visible="{= ${contactDetail>/contact/category} === 'acquirente' }">
                <f:content>
                    <Label text="{i18n>contactsDialogFieldRequestedArea}" />
                    <Input value="{contactDetail>/buyerProfile/requested_area}" />
                    <Label text="{i18n>contactsDialogFieldPropertyType}" />
                    <Input value="{contactDetail>/buyerProfile/property_type}" />
                    <Label text="{i18n>contactsDialogFieldFloorPreference}" />
                    <Select selectedKey="{contactDetail>/buyerProfile/floor_preference}" items="{favoriteFloor>/}">
                        <core:Item key="{favoriteFloor>key}" text="{favoriteFloor>value}" />
                    </Select>
                    <Label text="{i18n>contactsDialogFieldBudgetRenovated}" />
                    <Input value="{contactDetail>/buyerProfile/purchase_price_renovated}" type="Number" />
                    <Label text="{i18n>contactsDialogFieldBudgetToRenovate}" />
                    <Input value="{contactDetail>/buyerProfile/purchase_price_to_renovate}" type="Number" />
                    <Label text="{i18n>contactsDialogFieldMortgage}" />
                    <Select selectedKey="{contactDetail>/buyerProfile/mortgage_type}" items="{valueMutuo>/}">
                        <core:Item key="{valueMutuo>key}" text="{valueMutuo>value}" />
                    </Select>
                    <Label text="{i18n>contactsDialogFieldMortgageDetail}" visible="{= ${contactDetail>/buyerProfile/mortgage_type} === 'altro' }" />
                    <TextArea
                        rows="3"
                        value="{contactDetail>/buyerProfile/mortgage_other}"
                        visible="{= ${contactDetail>/buyerProfile/mortgage_type} === 'altro' }" />
                    <Label text="{i18n>contactsDialogFieldPreferences}" />
                    <VBox>
                        <CheckBox text="{i18n>contactsDialogPreferenceBox}" selected="{contactDetail>/buyerProfile/preferences/box}" />
                        <CheckBox text="{i18n>contactsDialogPreferenceParking}" selected="{contactDetail>/buyerProfile/preferences/posto_auto}" />
                        <CheckBox text="{i18n>contactsDialogPreferenceCellar}" selected="{contactDetail>/buyerProfile/preferences/cantina}" />
                        <CheckBox text="{i18n>contactsDialogPreferenceTerrace}" selected="{contactDetail>/buyerProfile/preferences/terrazzo}" />
                        <CheckBox text="{i18n>contactsDialogPreferenceOther}" selected="{contactDetail>/buyerProfile/preferences/altro}" />
                    </VBox>
                    <Label text="{i18n>contactsDialogFieldPreferenceOther}" visible="{= ${contactDetail>/buyerProfile/preferences/altro} }" />
                    <Input value="{contactDetail>/buyerProfile/preference_other}" visible="{= ${contactDetail>/buyerProfile/preferences/altro} }" />
                </f:content>
            </f:SimpleForm>

            <Toolbar class="sapUiSmallMarginTop sapUiTinyMarginBottom">
                <ToolbarSpacer />
                <Button text="{i18n>contactDetailSaveButton}" type="Emphasized" icon="sap-icon://save" press="onSaveContact" />
            </Toolbar>

            <Panel headerText="{i18n>contactDetailActivitiesTitle}" expandable="true" expanded="true" class="sapUiSmallMarginTop">
                <headerToolbar>
                    <OverflowToolbar>
                        <Title text="{i18n>contactDetailActivitiesTitle}" level="H4" />
                        <ToolbarSpacer />
                        <SearchField id="activitySearchField" width="14rem" placeholder="{i18n>contactDetailActivitiesFilterPlaceholder}" liveChange="onFilterActivities" search="onFilterActivities" />
                        <Select width="10rem" selectedKey="" change="onFilterActivities" id="activityStatusFilter">
                            <core:Item key="" text="{i18n>contactDetailActivityStatusAll}" />
                            <core:Item key="todo" text="{i18n>contactDetailActivityStatusTodo}" />
                            <core:Item key="in_corso" text="{i18n>contactDetailActivityStatusInProgress}" />
                            <core:Item key="completata" text="{i18n>contactDetailActivityStatusCompleted}" />
                        </Select>
                        <Button text="{i18n>contactDetailAddButton}" icon="sap-icon://add" press="onAddActivity" />
                    </OverflowToolbar>
                </headerToolbar>
                <List id="activitiesList" items="{contactDetail>/activities}" noDataText="{i18n>contactDetailActivitiesNoData}">
                    <CustomListItem>
                        <VBox>
                            <Title text="{contactDetail>title}" level="H5" />
                            <Text text="{contactDetail>description}" />
                            <HBox renderType="Bare" class="sapUiTinyMarginTop">
                                <ObjectStatus text="{contactDetail>priority}" state="Information" class="sapUiTinyMarginEnd" />
                                <ObjectStatus text="{contactDetail>status}" state="{= ${contactDetail>status} === 'completata' ? 'Success' : 'Warning'}" />
                            </HBox>
                        </VBox>
                    </CustomListItem>
                </List>
            </Panel>

            <Panel headerText="{i18n>contactDetailNotesTitle}" expandable="true" expanded="true" class="sapUiSmallMarginTop">
                <headerToolbar>
                    <OverflowToolbar>
                        <Title text="{i18n>contactDetailNotesTitle}" level="H4" />
                        <ToolbarSpacer />
                        <SearchField width="14rem" placeholder="{i18n>contactDetailNotesFilterPlaceholder}" liveChange="onFilterNotes" search="onFilterNotes" />
                        <Button text="{i18n>contactDetailAddButton}" icon="sap-icon://add" press="onAddNote" />
                    </OverflowToolbar>
                </headerToolbar>
                <List id="notesList" items="{contactDetail>/notes}" noDataText="{i18n>contactDetailNotesNoData}">
                    <StandardListItem title="{contactDetail>message}" description="{= ${i18n>contactDetailNoteCreatedAtPrefix} + ${contactDetail>created_at}}" />
                </List>
            </Panel>
        </content>
    </Page>
</mvc:View>
