<mvc:View
    controllerName="crm.controller.contactTile.ContactDetail"
    xmlns="sap.m"
    xmlns:mvc="sap.ui.core.mvc"
    xmlns:core="sap.ui.core"
    xmlns:f="sap.ui.layout.form">
    <core:Fragment fragmentName="crm.view.fragments.ShellBar" type="XML"/>
    <Page title="Dettaglio contatto" class="sapUiResponsiveContentPadding" navButtonPress="onNavBack" showNavButton="true">
        <content>
            <ObjectHeader
                title="{= ${contactDetail>/contact/first_name} + ' ' + ${contactDetail>/contact/last_name}}"
                number="{contactDetail>/contact/id}"
                numberUnit="ID"
                intro="{contactDetail>/contact/category}"
                responsive="true">
                <attributes>
                    <ObjectAttribute text="Email: {contactDetail>/contact/email}" />
                    <ObjectAttribute text="PEC: {contactDetail>/contact/pec_email}" />
                </attributes>
                <statuses>
                    <ObjectStatus
                        text="{contactDetail>/contact/status}"
                        state="{= ${contactDetail>/contact/status} === 'Attivo' || ${contactDetail>/contact/status} === 'attivo' ? 'Success' : (${contactDetail>/contact/status} === 'Futuro' || ${contactDetail>/contact/status} === 'futuro' ? 'Warning' : 'None')}" />
                </statuses>
            </ObjectHeader>

            <f:SimpleForm editable="true" layout="ResponsiveGridLayout" title="Dati contatto" class="sapUiSmallMarginTop">
                <f:content>
                    <Label text="Nome" />
                    <Input value="{contactDetail>/contact/first_name}" />
                    <Label text="Cognome" />
                    <Input value="{contactDetail>/contact/last_name}" />
                    <Label text="Email" />
                    <Input value="{contactDetail>/contact/email}" type="Email" />
                    <Label text="PEC" />
                    <Input value="{contactDetail>/contact/pec_email}" type="Email" />
                    <Label text="Categoria" />
                    <Select selectedKey="{contactDetail>/contact/category}" items="{categoriesContact>/}">
                        <core:Item key="{categoriesContact>key}" text="{categoriesContact>value}" />
                    </Select>
                    <Label text="Stato" />
                    <Select selectedKey="{contactDetail>/contact/status}" items="{statesContact>/}">
                        <core:Item key="{statesContact>key}" text="{statesContact>value}" />
                    </Select>
                    <Label text="Informazioni" />
                    <TextArea rows="4" value="{contactDetail>/contact/generic_info}" />
                </f:content>
            </f:SimpleForm>

            <f:SimpleForm
                editable="true"
                layout="ResponsiveGridLayout"
                title="Profilo acquirente"
                class="sapUiSmallMarginTop"
                visible="{= ${contactDetail>/contact/category} === 'acquirente' }">
                <f:content>
                    <Label text="Zona richiesta" />
                    <Input value="{contactDetail>/buyerProfile/requested_area}" />
                    <Label text="Tipologia immobile" />
                    <Input value="{contactDetail>/buyerProfile/property_type}" />
                    <Label text="Piano preferito" />
                    <Select selectedKey="{contactDetail>/buyerProfile/floor_preference}" items="{favoriteFloor>/}">
                        <core:Item key="{favoriteFloor>key}" text="{favoriteFloor>value}" />
                    </Select>
                    <Label text="Budget ristrutturato" />
                    <Input value="{contactDetail>/buyerProfile/purchase_price_renovated}" type="Number" />
                    <Label text="Budget da ristrutturare" />
                    <Input value="{contactDetail>/buyerProfile/purchase_price_to_renovate}" type="Number" />
                    <Label text="Mutuo" />
                    <Select selectedKey="{contactDetail>/buyerProfile/mortgage_type}" items="{valueMutuo>/}">
                        <core:Item key="{valueMutuo>key}" text="{valueMutuo>value}" />
                    </Select>
                    <Label text="Dettaglio mutuo" visible="{= ${contactDetail>/buyerProfile/mortgage_type} === 'altro' }" />
                    <TextArea
                        rows="3"
                        value="{contactDetail>/buyerProfile/mortgage_other}"
                        visible="{= ${contactDetail>/buyerProfile/mortgage_type} === 'altro' }" />
                    <Label text="Preferenze" />
                    <VBox>
                        <CheckBox text="Box" selected="{contactDetail>/buyerProfile/preferences/box}" />
                        <CheckBox text="Posto auto" selected="{contactDetail>/buyerProfile/preferences/posto_auto}" />
                        <CheckBox text="Cantina" selected="{contactDetail>/buyerProfile/preferences/cantina}" />
                        <CheckBox text="Terrazzo" selected="{contactDetail>/buyerProfile/preferences/terrazzo}" />
                        <CheckBox text="Altro" selected="{contactDetail>/buyerProfile/preferences/altro}" />
                    </VBox>
                    <Label text="Altro preferenze" visible="{= ${contactDetail>/buyerProfile/preferences/altro} }" />
                    <Input value="{contactDetail>/buyerProfile/preference_other}" visible="{= ${contactDetail>/buyerProfile/preferences/altro} }" />
                </f:content>
            </f:SimpleForm>

            <Toolbar class="sapUiSmallMarginTop sapUiTinyMarginBottom">
                <ToolbarSpacer />
                <Button text="Salva contatto" type="Emphasized" icon="sap-icon://save" press="onSaveContact" />
            </Toolbar>

            <Panel headerText="Attività" expandable="true" expanded="true" class="sapUiSmallMarginTop">
                <headerToolbar>
                    <OverflowToolbar>
                        <Title text="Attività" level="H4" />
                        <ToolbarSpacer />
                        <SearchField id="activitySearchField" width="14rem" placeholder="Filtra attività" liveChange="onFilterActivities" search="onFilterActivities" />
                        <Select width="10rem" selectedKey="" change="onFilterActivities" id="activityStatusFilter">
                            <core:Item key="" text="Tutti" />
                            <core:Item key="todo" text="To do" />
                            <core:Item key="in_corso" text="In corso" />
                            <core:Item key="completata" text="Completata" />
                        </Select>
                        <Button text="Aggiungi" icon="sap-icon://add" press="onAddActivity" />
                    </OverflowToolbar>
                </headerToolbar>
                <List id="activitiesList" items="{contactDetail>/activities}" noDataText="Nessuna attività registrata">
                    <CustomListItem>
                        <VBox>
                            <Title text="{contactDetail>title}" level="H5" />
                            <Text text="{contactDetail>description}" />
                            <HBox renderType="Bare" class="sapUiTinyMarginTop">
                                <ObjectStatus text="{contactDetail>priority}" state="Information" class="sapUiTinyMarginEnd" />
                                <ObjectStatus text="{contactDetail>status}" state="{= ${contactDetail>status} === 'completata' ? 'Success' : 'Warning'}" />
                            </HBox>
                        </VBox>
                    </CustomListItem>
                </List>
            </Panel>

            <Panel headerText="Note" expandable="true" expanded="true" class="sapUiSmallMarginTop">
                <headerToolbar>
                    <OverflowToolbar>
                        <Title text="Note" level="H4" />
                        <ToolbarSpacer />
                        <SearchField width="14rem" placeholder="Filtra note" liveChange="onFilterNotes" search="onFilterNotes" />
                        <Button text="Aggiungi" icon="sap-icon://add" press="onAddNote" />
                    </OverflowToolbar>
                </headerToolbar>
                <List id="notesList" items="{contactDetail>/notes}" noDataText="Nessuna nota registrata">
                    <StandardListItem title="{contactDetail>message}" description="Creata il: {contactDetail>created_at}" />
                </List>
            </Panel>
        </content>
    </Page>
</mvc:View>
