<mvc:View
    controllerName="crm.controller.contactTile.Contacts"
    xmlns="sap.m"
    xmlns:mvc="sap.ui.core.mvc"
    xmlns:core="sap.ui.core"
    xmlns:f="sap.ui.layout.form">
    <core:Fragment fragmentName="crm.view.fragments.ShellBar" type="XML"/>
    <Page title="{i18n>contactsPageTitle}" class="sapUiResponsiveContentPadding">
        <content>
            <Panel class="sapUiTinyMarginBottom" expandable="true">
                <headerToolbar>
                    <Toolbar>
                        <Title text="{i18n>contactsFiltersTitle}" level="H5" />
                    </Toolbar>
                </headerToolbar>
                <content>
                    <f:SimpleForm
                        editable="true"
                        layout="ColumnLayout"
                        labelSpanXL="2"
                        labelSpanL="2"
                        labelSpanM="12"
                        labelSpanS="12"
                        emptySpanXL="0"
                        emptySpanL="0"
                        emptySpanM="0"
                        emptySpanS="0"
                        columnsXL="3"
                        columnsL="3"
                        columnsM="2"
                        singleContainerFullSize="false">
                        <Label text="{i18n>contactsFilterSearchLabel}" labelFor="contactSearchField" />
                        <SearchField
                            id="contactSearchField"
                            width="100%"
                            value="{contactFilters>/searchQuery}"
                            placeholder="{i18n>contactsFilterSearchPlaceholder}"
                            liveChange="onFilterChange"
                            search="onFilterChange" />
                        <Label text="{i18n>contactsFilterCategoryLabel}" labelFor="categorySelect" />
                        <Select
                            id="categorySelect"
                            width="100%"
                            forceSelection="false"
                            selectedKey="{contactFilters>/categoryKey}"
                            change="onFilterChange"
                            items="{categoriesContact>/}">
                            <core:Item key="" text="{i18n>contactsFilterCategoryAll}" />
                            <core:Item key="{categoriesContact>key}" text="{categoriesContact>value}" />
                        </Select>
                        <Label text="{i18n>contactsFilterStatusLabel}" labelFor="statusSelect" />
                        <Select
                            id="statusSelect"
                            width="100%"
                            forceSelection="false"
                            selectedKey="{contactFilters>/statusKey}"
                            change="onFilterChange"
                            items="{statesContact>/}">
                            <core:Item key="" text="{i18n>contactsFilterStatusAll}" />
                            <core:Item key="{statesContact>key}" text="{statesContact>value}" />
                        </Select>
                    </f:SimpleForm>
                    <Button text="{i18n>contactsFilterClearButton}" icon="sap-icon://clear-filter" type="Transparent" press="onClearFilters" />
                </content>
            </Panel>

            <Table
                id="contactsTable"
                mode="SingleSelectLeft"
                growing="true"
                growingScrollToLoad="true"
                busy="{contacts>/busy}"
                items="{contacts>/contacts}"
                selectionChange="onSelectionChange"
                noDataText="{i18n>contactsTableNoData}">
                <headerToolbar>
                    <OverflowToolbar>
                        <Title text="{= ${i18n>contactsTableTitlePrefix} + ${contacts>/contacts}.length + ')' }" level="H3" />
                        <ToolbarSpacer />
                        <Button icon="sap-icon://refresh" tooltip="{i18n>contactsTableRefreshTooltip}" press="onRefreshContacts" />
                        <Button text="{i18n>contactsTableSortButton}" icon="sap-icon://sort" press="onOpenSortDialog" />
                        <Button text="{i18n>contactsTableNewButton}" type="Emphasized" icon="sap-icon://add" press="onCreateContact" />
                        <Button text="{i18n>contactsTableEditButton}" icon="sap-icon://edit" enabled="{= !!${contacts>/selectedContactId}}" press="onEditContact" />
                        <Button text="{i18n>contactsTableDeleteButton}" type="Negative" icon="sap-icon://delete" enabled="{= !!${contacts>/selectedContactId}}" press="onDeleteContact" />
                    </OverflowToolbar>
                </headerToolbar>
                <columns>
                    <Column width="13rem"><Text text="{i18n>contactsTableColumnName}" /></Column>
                    <Column width="15rem"><Text text="{i18n>contactsTableColumnEmail}" /></Column>
                    <Column width="10rem"><Text text="{i18n>contactsTableColumnCategory}" /></Column>
                    <Column width="8rem"><Text text="{i18n>contactsTableColumnStatus}" /></Column>
                    <Column width="8rem" hAlign="End"><Text text="{i18n>contactsTableColumnActions}" /></Column>
                </columns>
                <items>
                    <ColumnListItem type="Navigation" press="onOpenDetail">
                        <cells>
                            <ObjectIdentifier title="{= ${contacts>first_name} + ' ' + ${contacts>last_name}}" text="{= ${i18n>contactsTableIdPrefix} + ${contacts>id}}" />
                            <Text text="{contacts>email}" />
                            <ObjectStatus text="{contacts>category}" state="Information" />
                            <ObjectStatus
                                text="{contacts>status}"
                                state="{= ${contacts>status} === 'Attivo' || ${contacts>status} === 'attivo' ? 'Success' : (${contacts>status} === 'Futuro' || ${contacts>status} === 'futuro' ? 'Warning' : 'None')}" />
                            <HBox justifyContent="End">
                                <Button icon="sap-icon://edit" type="Transparent" press="onRowEdit" />
                                <Button icon="sap-icon://delete" type="Transparent" press="onRowDelete" />
                            </HBox>
                        </cells>
                    </ColumnListItem>
                </items>
            </Table>
        </content>
    </Page>
</mvc:View>
