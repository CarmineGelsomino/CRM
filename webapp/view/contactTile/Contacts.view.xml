<mvc:View
    controllerName="crm.controller.contactTile.Contacts"
    xmlns="sap.m"
    xmlns:mvc="sap.ui.core.mvc"
    xmlns:core="sap.ui.core">
    <Page title="Contatti" class="sapUiResponsiveContentPadding">
        <content>
            <VBox class="sapUiSmallMarginBottom">
                <Toolbar>
                    <Title text="Filtri" level="H5" />
                    <ToolbarSpacer />
                    <SearchField width="20rem" placeholder="Cerca per nome, email o telefono" search="onSearch" liveChange="onSearchLiveChange" />
                    <Select id="statusFilter" width="10rem" change="onFilterChange" selectedKey="all">
                        <items>
                            <core:Item key="all" text="Tutti gli stati" />
                            <core:Item key="attivo" text="Attivo" />
                            <core:Item key="inattivo" text="Inattivo" />
                            <core:Item key="prospect" text="Prospect" />
                        </items>
                    </Select>
                    <Select id="categoryFilter" width="11rem" change="onFilterChange" selectedKey="all">
                        <items>
                            <core:Item key="all" text="Tutte le categorie" />
                            <core:Item key="cliente" text="Cliente" />
                            <core:Item key="fornitore" text="Fornitore" />
                            <core:Item key="partner" text="Partner" />
                        </items>
                    </Select>
                    <Select id="sortSelect" width="12rem" change="onSortChange" selectedKey="last_name">
                        <items>
                            <core:Item key="last_name" text="Ordina per cognome" />
                            <core:Item key="status" text="Ordina per stato" />
                            <core:Item key="category" text="Ordina per categoria" />
                        </items>
                    </Select>
                    <ToggleButton text="Desc" press="onToggleSortDirection" />
                </Toolbar>
            </VBox>

            <Table
                id="contactsTable"
                mode="SingleSelectLeft"
                items="{contacts>/contacts}"
                selectionChange="onSelectionChange"
                noDataText="Nessun contatto disponibile">
                <headerToolbar>
                    <OverflowToolbar>
                        <Title text="Elenco contatti" level="H4" />
                        <ToolbarSpacer />
                        <Button text="Crea" type="Emphasized" icon="sap-icon://add" press="onCreateContact" />
                        <Button text="Modifica" icon="sap-icon://edit" press="onEditContact" />
                        <Button text="Elimina" type="Negative" icon="sap-icon://delete" press="onDeleteContact" />
                    </OverflowToolbar>
                </headerToolbar>
                <columns>
                    <Column><Text text="Nome" /></Column>
                    <Column><Text text="Email" /></Column>
                    <Column><Text text="Telefono" /></Column>
                    <Column><Text text="Categoria" /></Column>
                    <Column><Text text="Stato" /></Column>
                </columns>
                <items>
                    <ColumnListItem type="Navigation" press="onItemPress">
                        <cells>
                            <Text text="{= ${contacts>first_name} + ' ' + ${contacts>last_name}}" />
                            <Text text="{contacts>email}" />
                            <Text text="{contacts>phone}" />
                            <ObjectStatus text="{contacts>category}" state="Information" />
                            <ObjectStatus text="{contacts>status}" />
                        </cells>
                    </ColumnListItem>
                </items>
            </Table>
        </content>
    </Page>
</mvc:View>
