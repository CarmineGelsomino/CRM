<core:FragmentDefinition
    xmlns="sap.m"
    xmlns:core="sap.ui.core"
    xmlns:tnt="sap.tnt"
    xmlns:f="sap.f">
    <tnt:ToolHeader>
        <Button icon="sap-icon://nav-back" type="Transparent" press="onShellNavHome" tooltip="{i18n>shellMenuHome}" />
        <Image src="img/logo.webp" decorative="true" tooltip="{i18n>shellBarTitle}">
			<layoutData>
				<OverflowToolbarLayoutData priority="NeverOverflow"/>
			</layoutData>
		</Image>
        <Title text="{i18n>shellBarTitle}" level="H5" />
        <ToolbarSpacer />
        <MenuButton icon="sap-icon://menu2" type="Neutral" tooltip="{i18n>shellMenuTooltip}">
            <menu>
                <Menu itemSelected="onShellMainMenuSelect">
                    <items>
                        <MenuItem text="{i18n>shellMenuHome}" icon="sap-icon://home" />
                        <MenuItem text="{i18n>shellMenuContacts}" icon="sap-icon://customer" />
                        <MenuItem text="{i18n>shellMenuProperties}" icon="sap-icon://building" />
                        <MenuItem text="{i18n>shellMenuNotes}" icon="sap-icon://notes" />
                        <MenuItem text="{i18n>shellMenuDeals}" icon="sap-icon://business-objects-experience" />
                        <MenuItem text="{i18n>shellMenuTickets}" icon="sap-icon://sys-help" />
                        <MenuItem text="{i18n>shellMenuProfile}" icon="sap-icon://employee" />
                    </items>
                </Menu>
            </menu>
        </MenuButton>
        <Button icon="sap-icon://bell" type="Transparent" press="onShellNotificationsPress" tooltip="{i18n>shellNotificationsTooltip}" />
        <f:Avatar
            displaySize="XS"
            displayShape="Circle"
            initials="{ parts: [ { path: 'session>/firstName' }, { path: 'session>/lastName' }, { path: 'session>/email' } ], formatter: '.formatUserInitials' }"
            tooltip="{i18n>shellProfileTooltip}"
            press="onShellProfilePress" />
    </tnt:ToolHeader>
</core:FragmentDefinition>
